# PiLNK — files git should never track

# Sensitive / per-node config
.secret_key
config.json

# Runtime / generated files
update.log
stats_records.json
coverage.json
ota_state.json
__pycache__/
*.pyc
*.pyo

# Editor / OS noise
.vscode/
.idea/
.DS_Store
*.swp

# Backup files (we should never commit these — they should never exist
# in the repo, but ignoring them prevents future accidents)
*.bak
*.bak.*

# Dev artifacts / scratch / runtime data (never belong in the repo)
_airspy_syntax_check.sh
aircraft.csv.gz
aircraft-overlay.csv.gz
recordings/
